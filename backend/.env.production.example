# Production Environment Variables for Backend
# Copy these to Railway environment variables - DO NOT commit this file with real values!

# Database - Replace with Railway PostgreSQL URL
DATABASE_URL=postgresql://user:password@host:5432/worldcup

# Security - IMPORTANT: Use the generated secure key!
# Generated key: 0HFoI7Txu8SDNtg6fiEvWjALVw1sRTT5yKTOWV-w6oE
SECRET_KEY=0HFoI7Txu8SDNtg6fiEvWjALVw1sRTT5yKTOWV-w6oE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Update with your Vercel domain after frontend deployment
CORS_ORIGINS=https://your-app.vercel.app,https://www.your-app.vercel.app

# Environment
ENVIRONMENT=production

# Port (Railway will set this automatically)
PORT=8000

# OAuth (Optional - leave empty if not using)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
